{
  "name": "opaque-stellar",
  "private": true,
  "type": "module",
  "scripts": {
    "deploy": "tsx scripts/deploy-contracts.ts",
    "deploy:testnet": "tsx scripts/deploy-contracts.ts --network testnet",
    "deploy:mainnet": "tsx scripts/deploy-contracts.ts --network mainnet",
    "deploy:rollback": "node scripts/rollback-deployment.mjs --dry-run",
    "health:rpc": "node scripts/probe-horizon-rpc.mjs",
    "verify:deployment": "tsx scripts/verify-deployment-manifest.ts",
    "verify:sdk-readonly-version": "tsx scripts/verify-sdk-readonly-version.ts",
    "verify:deployment:strict": "tsx scripts/verify-deployment-manifest.ts --strict",
    "verify:security-audit": "tsx scripts/verify-security-audit.ts --network mainnet",
    "update:manifest-wasm": "tsx scripts/update-manifest-wasm-hashes.ts",
    "build:scanner": "tsx scripts/build-scanner-wasm.ts",
    "build:scanner:simd": "cd scanner && RUSTFLAGS=\"-C target-feature=+simd128,+bulk-memory\" wasm-pack build --release --target web --profile wasm-simd --out-dir ../frontend/public/pkg",
    "bench:scanner": "cd scanner && cargo bench --bench scanner_perf",
    "bench:scanner:simd": "cd scanner && RUSTFLAGS=\"-C target-feature=+simd128\" cargo bench --bench scanner_perf",
    "fetch:circuits": "tsx scripts/fetch-circuit-artifacts.ts",
    "verify:artifacts": "tsx scripts/verify-artifact-manifest.ts",
    "example:simulate-attest": "tsx examples/simulate-attest.ts --dry-run",
    "update:artifacts": "tsx scripts/update-artifact-manifest.ts --sync-deployments --embedded-vk",
    "prepare:frontend": "tsx scripts/prepare-frontend-artifacts.ts",
    "test:circuits": "npm run test:regression --prefix circuits",
    "ci:local": "bash scripts/ci-local.sh",
    "audit:supply-chain": "bash scripts/check-npm-audit.sh",
    "check:wasm-sizes": "tsx scripts/check-wasm-sizes.ts",
    "sign:artifacts": "tsx scripts/sign-release-artifacts.ts",
    "verify:signatures": "tsx scripts/verify-artifact-signatures.ts"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "audit-ci": "^7.1.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
