# Stellar network: testnet | futurenet | mainnet | local
VITE_STELLAR_NETWORK=testnet

# Soroban RPC (optional; defaults from deployments/v1/<network>.json)
# VITE_STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Horizon (optional)
# VITE_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Canonical contract IDs live in deployments/v1/<network>.json.
# Override only for local development (non-production builds):
# VITE_TESTNET_STEALTH_REGISTRY_CONTRACT=
# VITE_TESTNET_STEALTH_ANNOUNCER_CONTRACT=
# VITE_TESTNET_GROTH16_VERIFIER_CONTRACT=
# VITE_TESTNET_REPUTATION_VERIFIER_CONTRACT=
# VITE_TESTNET_SCHEMA_REGISTRY_CONTRACT=
# VITE_TESTNET_ATTESTATION_ENGINE_CONTRACT=

# Mainnet overrides (required until deployments/v1/mainnet.json is populated):
# VITE_MAINNET_STEALTH_REGISTRY_CONTRACT=
# ...

# Scanner chunk size: number of announcements processed per WASM batch in the
# background worker. Higher values increase throughput; lower values keep the
# progress bar more responsive. Default: 200.
# VITE_SCANNER_CHUNK_SIZE=200
